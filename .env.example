# 브이월드(VWorld) Open API 인증키 (필수)
# 발급: https://www.vworld.kr/dev/v4dv_apikey_s001.do
# 발급 시 사용 도메인/IP를 등록해야 하며, 등록되지 않은 도메인에서 호출하면 차단됩니다.
VWORLD_KEY=your-vworld-api-key-here

# VWorld API 키 신청 시 등록한 서비스URL과 정확히 일치해야 함 (필수에 가까움)
# 검색 API(주소→PNU)는 이 값이 없어도 동작하지만, 2D데이터·국가중점(NED) API는
# 이 값이 없거나 등록된 서비스URL과 다르면 INCORRECT_KEY 에러가 발생함
# 예: http://your-server-domain-or-ip
VWORLD_DOMAIN=http://localhost

# 지적도 DXF 파일 저장 경로 (선택, 미지정 시 ./output)
# DXF_OUTPUT_DIR=C:\Users\you\Desktop\cadastral-output

# export_land_report_dxf의 지적도 XCLIP(공간 필터) 크롭에 사용할 Python 실행 파일 경로 (선택)
# 미지정 시 python3 -> python -> py 순서로 자동탐지. `pip install ezdxf` 필요.
# 자동탐지가 ezdxf 없는 다른 Python을 먼저 찾을 때만 지정하면 됨.
# CADASTRAL_PYTHON=C:\Users\you\path\to\python.exe

# 법제처 Open API 인증키 (선택 — 없으면 건폐율/용적률/조경이 국가법령 상한으로만 표시됨)
# 발급: https://open.law.go.kr/LSO/openApi/guideResult.do (무료, 즉시 발급)
# export_land_report_dxf가 필지 소재 지자체의 도시계획조례·건축조례를 자동 검색해
# 실제 건폐율/용적률/조경 기준을 채우는 데 사용. korean-law-mcp를 이미 쓰고 있어도
# 별도 프로세스라 키를 공유할 수 없어 따로 발급해야 함.
LAW_OC=your-law-oc-key-here
